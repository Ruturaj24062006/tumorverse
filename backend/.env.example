# Cancer Prediction API - Environment Variables
# Copy this file to .env and adjust values as needed

# API Configuration
API_TITLE="Cancer Type Prediction API"
API_VERSION="1.0.0"
API_HOST="0.0.0.0"
API_PORT=8000
DEBUG=false

# Model Configuration (relative to backend directory)
CLASSIFIER_PATH="model/tumor_classifier.pkl"
PCA_MODEL_PATH="model/pca_model.pkl"
LABEL_ENCODER_PATH="model/label_encoder.pkl"

# Feature Configuration
EXPECTED_FEATURES=20531
PCA_COMPONENTS=500

# CORS Configuration
# For local development:
# CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000"]
# For production, specify allowed origins:
# CORS_ORIGINS=["https://yourdomain.com"]
CORS_CREDENTIALS=true

# Logging
LOG_LEVEL=info

# Frontend URL
NEXT_PUBLIC_API_URL="http://localhost:8000"
